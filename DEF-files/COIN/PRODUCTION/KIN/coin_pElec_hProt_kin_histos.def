############################
#   MISSING MASS
############################
# Plot m_miss squared because I don't trust the square root
#formula mmiss H.kin.secondary.emiss_nuc*H.kin.secondary.emiss_nuc-H.kin.secondary.pmiss*H.kin.secondary.pmiss
formula mmiss H.kin.secondary.emiss*H.kin.secondary.emiss-H.kin.secondary.pmiss*H.kin.secondary.pmiss
TH1F hkin_mmiss                   'HMS M^{2}_{miss} (ccleantrack); M^{2}_{miss} (GeV); Count / 0.001 GeV2'  mmiss 200 -0.1 0.1 ccleantrack 
#TH1F hkin_mmiss_coincut          'HMS M^{2}_{miss} (coincut); M^{2}_{miss} (GeV); Count / 0.001 GeV'       mmiss 200 -0.1 0.1 coincut
#TH1F hkin_mmiss_coincut_ep       'HMS M^{2}_{miss} (coincut_ep); M^{2}_{miss} (GeV); Count / 0.001 GeV'    mmiss 200 -0.1 0.1 pcoincut_ep
#TH1F hkin_mmiss_tightcut         'HMS M^{2}_{miss} (tight_coin); M^{2}_{miss} (GeV); Count / 0.001 GeV'    mmiss 200 -0.1 0.1 tight_coin&&pselect_e_cut&&pbetacut_proton
#TH1F hkin_mmiss_ran_coincut      'HMS M^{2}_{miss} (ran_coincut); M^{2}_{miss} (GeV); Count / 0.001 GeV'   mmiss 200 -0.1 0.1 ran_coincut&&pselect_e_cut&&pbetacut_proton
#TH1F hkin_mmiss_coinpeak_kin_2d   'HMS M^{2}_{miss} (coin peak kin 2d); M^{2}_{miss} (GeV); Count / 0.001 GeV2'  mmiss 200 -0.1 0.1 coinpeak_kin_2d
#TH1F hkin_mmiss_sideband_kin_2d   'HMS M^{2}_{miss} (sideband kin 2d); M^{2}_{miss} (GeV); Count / 0.001 GeV2'  mmiss 200 -0.1 0.1 sideband_kin_2d
TH1F hkin_mmiss_coinpeak_kin_3d   'HMS M^{2}_{miss} (coin peak kin 3d); M^{2}_{miss} (GeV); Count / 0.001 GeV2'  mmiss 200 -0.1 0.1 coinpeak_kin_3d
TH1F hkin_mmiss_sideband_kin_3d   'HMS M^{2}_{miss} (sideband kin 3d); M^{2}_{miss} (GeV); Count / 0.001 GeV2'  mmiss 200 -0.1 0.1 sideband_kin_3d


############################
#   MISSING MOMENTUM
############################
TH1F hkin_pmiss              'HMS p_{miss} Magnitude (ccleantrack); p_{miss} (GeV); Count / 0.02 GeV;'  H.kin.secondary.pmiss          200 -2 2 ccleantrack
#TH1F hkin_pmiss_coincut      'HMS p_{miss} Magnitude (coincut); p_{miss} (GeV); Count / 0.02 GeV;'      H.kin.secondary.pmiss          200 -2 2 coincut
#TH1F hkin_pmiss_pid          'HMS p_{miss} Magnitude (coincut_ep); p_{miss} (GeV); Count / 0.02 GeV;'   H.kin.secondary.pmiss          200 -2 2 pcoincut_ep
#TH1F hkin_pmiss_x            'HMS p_{miss,x} (coincut_ep); p_{miss,x} (GeV); Count / 0.02 GeV;'         H.kin.secondary.pmiss_x        200 -2 2 pcoincut_ep
#TH1F hkin_pmiss_y            'HMS p_{miss,y} (coincut_ep); p_{miss,y} (GeV); Count / 0.02 GeV;'         H.kin.secondary.pmiss_y        200 -2 2 pcoincut_ep
#TH1F hkin_pmiss_z            'HMS p_{miss,z} (coincut_ep); p_{miss,z} (GeV); Count / 0.02 GeV;'         H.kin.secondary.pmiss_z        200 -2 2 pcoincut_ep

############################
#   MISSING ENERG0Y
############################
TH1F hkin_Emiss              'HMS E_{miss} (ccleantrack); E_{miss} (GeV); Count / 0.01 GeV;' H.kin.secondary.emiss_nuc 400 -1 3 ccleantrack
#TH1F hkin_Emiss_coincut      'HMS E_{miss} (coincut); E_{miss} (GeV); Count / 0.01 GeV;'     H.kin.secondary.emiss_nuc 400 -1 3 coincut
#TH1F hkin_Emiss_pid          'HMS E_{miss} (coincut_ep); E_{miss} (GeV); Count / 0.01 GeV;'  H.kin.secondary.emiss_nuc 400 -1 3 pcoincut_ep

############################
#   Theta PQ
############################
TH1F hkin_thpq_lab                      'HMS theta_{pq,lab} (ccleantrack)'; th_{pq, lab} (deg); Count / 0.5 deg;' 180.0/3.141592*H.kin.secondary.th_xq 180 0 90 ccleantrack
#TH1F hkin_thpq_lab_coinpeak_kin_2d      'HMS theta_{pq,lab} (coin peak kin 2d)'; th_{pq, lab} (deg); Count / 0.5 deg;' 180.0/3.141592*H.kin.secondary.th_xq 180 0 90 coinpeak_kin_2d
#TH1F hkin_thpq_lab_sideband_kin_2d     'HMS theta_{pq,lab} (sideband kin 2d); th_{pq, lab} (deg); Count / 0.5 deg;' 180.0/3.141592*H.kin.secondary.th_xq 180 0 90 sideband_kin_2d
TH1F hkin_thpq_lab_coinpeak_kin_3d      'HMS theta_{pq,lab} (coin peak kin 3d)'; th_{pq, lab} (deg); Count / 0.5 deg;' 180.0/3.141592*H.kin.secondary.th_xq 180 0 90 coinpeak_kin_3d
TH1F hkin_thpq_lab_sideband_kin_3d     'HMS theta_{pq,lab} (sideband kin 3d); th_{pq, lab} (deg); Count / 0.5 deg;' 180.0/3.141592*H.kin.secondary.th_xq 180 0 90 sideband_kin_3d
TH1F hkin_thpq_cm                       'HMS theta_{pq,cm} (ccleantrack); th_{pq, cm} (deg); Count / 0.5 deg;' 180.0/3.141592*H.kin.secondary.thx_cm 180 0 90 ccleantrack
#TH1F hkin_thpq_cm_coinpeak_kin_2d       'HMS theta_{pq,cm} (coin peak kin 2d); th_{pq, cm} (deg); Count / 0.5 deg;' 180.0/3.141592*H.kin.secondary.thx_cm 180 0 90 coinpeak_kin_2d
#TH1F hkin_thpq_cm_sideband_kin_2d      'HMS theta_{pq,cm} (sideband kin 2d); th_{pq, cm} (deg); Count / 0.5 deg;' 180.0/3.141592*H.kin.secondary.thx_cm 180 0 90 sideband_kin_2d
TH1F hkin_thpq_cm_coinpeak_kin_3d       'HMS theta_{pq,cm} (coin peak kin 3d); th_{pq, cm} (deg); Count / 0.5 deg;' 180.0/3.141592*H.kin.secondary.thx_cm 180 0 90 coinpeak_kin_3d
TH1F hkin_thpq_cm_sideband_kin_3d      'HMS theta_{pq,cm} (sideband kin 3d); th_{pq, cm} (deg); Count / 0.5 deg;' 180.0/3.141592*H.kin.secondary.thx_cm 180 0 90 sideband_kin_3d
TH1F hkin_phipq_cm                      'HMS phi_{pq,cm} (ccleantrack); phi_{pq, cm} (deg); Count / 0.5 deg;' 180.0/3.141592*H.kin.secondary.phx_cm 720 -180 180 ccleantrack
#TH1F hkin_phipq_cm_coinpeak_kin_2d      'HMS phi_{pq,cm} (coin peak kin 2d); phi_{pq, cm} (deg); Count / 0.5 deg;' 180.0/3.141592*H.kin.secondary.phx_cm 720 -180 180 coinpeak_kin_2d
#TH1F hkin_phipq_cm_sideband_kin_2d     'HMS phi_{pq,cm} (sideband kin 2d); phi_{pq, cm} (deg); Count / 0.5 deg;' 180.0/3.141592*H.kin.secondary.phx_cm 720 -180 180 sideband_kin_2d
TH1F hkin_phipq_cm_coinpeak_kin_3d      'HMS phi_{pq,cm} (coin peak kin 3d); phi_{pq, cm} (deg); Count / 0.5 deg;' 180.0/3.141592*H.kin.secondary.phx_cm 720 -180 180 coinpeak_kin_3d
TH1F hkin_phipq_cm_sideband_kin_3d     'HMS phi_{pq,cm} (sideband kin 3d); phi_{pq, cm} (deg); Count / 0.5 deg;' 180.0/3.141592*H.kin.secondary.phx_cm 720 -180 180 sideband_kin_3d

############################
#   KINEMATICS
############################
TH1F pkin_Q2                            'SHMS Q^{2} (ccleantrack); Q^{2} (GeV); Count / 0.01 GeV;' P.kin.primary.Q2 100 0 0.1  ccleantrack
#TH1F pkin_Q2_coinpeak_kin_2d            'SHMS Q^{2} (coin peak kin 2d); Q^{2} (GeV); Count / 0.01 GeV;' P.kin.primary.Q2 100 0 0.1  coinpeak_kin_2d
#TH1F pkin_Q2_sideband_kin_2d           'SHMS Q^{2} (sideband kin 2d); Q^{2} (GeV); Count / 0.01 GeV;' P.kin.primary.Q2 100 0 0.1  sideband_kin_2d
TH1F pkin_Q2_coinpeak_kin_3d            'SHMS Q^{2} (coin peak kin 3d); Q^{2} (GeV); Count / 0.01 GeV;' P.kin.primary.Q2 100 0 0.1  coinpeak_kin_3d
TH1F pkin_Q2_sideband_kin_3d           'SHMS Q^{2} (sideband kin 3d); Q^{2} (GeV); Count / 0.01 GeV;' P.kin.primary.Q2 100 0 0.1  sideband_kin_3d
TH1F pkin_W2                            'SHMS W^{2} (ccleantrack); W^{2} (GeV2); Count / 0.01 GeV2;' P.kin.primary.W2 400 0.0 4.0 ccleantrack
#TH1F pkin_W2_coinpeak_kin_2d            'SHMS W^{2} (coin peak kin 2d); W^{2} (GeV2); Count / 0.01 GeV2;' P.kin.primary.W2 400 0.0 4.0 coinpeak_kin_2d
#TH1F pkin_W2_sideband_kin_2d           'SHMS W^{2} (sideband kin 2d); W^{2} (GeV2); Count / 0.01 GeV2;' P.kin.primary.W2 400 0.0 4.0 sideband_kin_2d
TH1F pkin_W2_coinpeak_kin_3d            'SHMS W^{2} (coin peak kin 3d); W^{2} (GeV2); Count / 0.01 GeV2;' P.kin.primary.W2 400 0.0 4.0 coinpeak_kin_3d
TH1F pkin_W2_sideband_kin_3d           'SHMS W^{2} (sideband kin 3d); W^{2} (GeV2); Count / 0.01 GeV2;' P.kin.primary.W2 400 0.0 4.0 sideband_kin_3d
TH1F pkin_W                             'SHMS W (ccleantrack); W (GeV); Count / 0.001 GeV;' P.kin.primary.W 120 0.6 1.8 ccleantrack
#TH1F pkin_W_coinpeak_kin_2d             'SHMS W (coin peak kin 2d); W (GeV); Count / 0.001 GeV;' P.kin.primary.W 120 0.6 1.8 coinpeak_kin_2d
#TH1F pkin_W_sideband_kin_2d            'SHMS W (sideband kin 2d); W (GeV); Count / 0.001 GeV;' P.kin.primary.W 120 0.6 1.8 sideband_kin_2d
TH1F pkin_W_coinpeak_kin_3d             'SHMS W (coin peak kin 3d); W (GeV); Count / 0.001 GeV;' P.kin.primary.W 120 0.6 1.8 coinpeak_kin_3d
TH1F pkin_W_sideband_kin_3d            'SHMS W (sideband kin 3d); W (GeV); Count / 0.001 GeV;' P.kin.primary.W 120 0.6 1.8 sideband_kin_3d

TH2F hW_vs_th_pq 'W vs thpq_{cm} (ccleantrack); thpq_{cm} (deg); W (GeV)' 180.0/3.141592*H.kin.secondary.thx_cm P.kin.primary.W 180 0 90 120 0.6 1.8 ccleantrack
TH2F hQ2_vs_W 'Q2 vs W (ccleantrack); W (GeV); Q2 (GeV2)' P.kin.primary.W P.kin.primary.Q2 180 0.6 1.8 100 0 0.1 ccleantrack
TH2F hQ2_vs_th_pq 'Q2 vs thpq_{cm} (ccleantrack); thpq_{cm} (deg); Q2 (GeV2)' 180.0/3.141592*H.kin.secondary.thx_cm P.kin.primary.Q2 180 0 90 100 0 0.1 ccleantrack


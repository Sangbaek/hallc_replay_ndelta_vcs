############################
#   MISSING MASS
############################
# Plot m_miss squared because I don't trust the square root
#formula mmiss H.kin.secondary.emiss_nuc*H.kin.secondary.emiss_nuc-H.kin.secondary.pmiss*H.kin.secondary.pmiss
formula mmiss H.kin.secondary.emiss*H.kin.secondary.emiss-H.kin.secondary.pmiss*H.kin.secondary.pmiss
TH1F hkin_mmiss                   'HMS M^{2}_{miss} (ccleantrack); M^{2}_{miss} (GeV); Count / 0.001 GeV2'  mmiss 200 -0.1 0.1 ccleantrack 
#TH1F hkin_mmiss_coincut          'HMS M^{2}_{miss} (coincut); M^{2}_{miss} (GeV); Count / 0.001 GeV'       mmiss 200 -0.1 0.1 coincut
#TH1F hkin_mmiss_coincut_ep       'HMS M^{2}_{miss} (coincut_ep); M^{2}_{miss} (GeV); Count / 0.001 GeV'    mmiss 200 -0.1 0.1 pcoincut_ep
#TH1F hkin_mmiss_tightcut         'HMS M^{2}_{miss} (tight_coin); M^{2}_{miss} (GeV); Count / 0.001 GeV'    mmiss 200 -0.1 0.1 tight_coin&&pselect_e_cut&&pbetacut_proton
#TH1F hkin_mmiss_ran_coincut      'HMS M^{2}_{miss} (ran_coincut); M^{2}_{miss} (GeV); Count / 0.001 GeV'   mmiss 200 -0.1 0.1 ran_coincut&&pselect_e_cut&&pbetacut_proton
#TH1F hkin_mmiss_coinpeak_kin_1d   'HMS M^{2}_{miss} (coin peak kin 1d); M^{2}_{miss} (GeV); Count / 0.001 GeV2'  mmiss 200 -0.1 0.1 coinpeak_kin_1d

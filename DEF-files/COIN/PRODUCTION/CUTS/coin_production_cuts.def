SHMS_COIN_event      g.evtyp == 5
HMS_COIN_event       g.evtyp == 6 
COIN_ALL_event       g.evtyp == 7
ALL_events           SHMS_event || HMS_event || BOTH_SINGLES_event || COIN_ONLY_event || COIN_ALL_event


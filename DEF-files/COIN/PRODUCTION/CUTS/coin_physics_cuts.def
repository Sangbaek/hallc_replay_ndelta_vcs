Block: Physics

hcleantrack        H.gtr.index > -1
pcleantrack        P.gtr.index > -1
ccleantrack        hcleantrack && pcleantrack

coin_ndelta       abs(CTime.epCoinTime_ROC2-160) < 10 
coin_vcs2         abs(CTime.epCoinTime_ROC2-160) < 10 
sideband1         abs(CTime.epCoinTime_ROC2-180) < 10 
sideband2         abs(CTime.epCoinTime_ROC2-140) < 10 
sideband          sideband1 || sideband2

coincut            ccleantrack && goodctime
tight_coin         ccleantrack && tightctime
ran_coincut        ccleantrack && ranctime

he_cut_cal          H.cal.etottracknorm > 0.6 && H.cal.etottracknorm < 1.6
he_cut_cer          H.cer.npeSum > 0.5
hselect_e_cut       he_cut_cal && he_cut_cer
hbetacut_proton     P.gtr.beta > 0.3 && P.gtr.beta < 0.6
hcoincut_ep         ccleantrack && hselect_e_cut && hbetacut_proton

pe_cut_cal          P.cal.etottracknorm > 0.6# && P.cal.etottracknorm < 1.6
pe_cut_cer          P.hgcer.npeSum > 1 #0.5
pselect_e_cut       pe_cut_cal && pe_cut_cer
pbetacut_proton     H.gtr.beta > 0.3 && H.gtr.beta < 0.6
pcoincut_ep         ccleantrack && pselect_e_cut && pbetacut_proton

h_mom_acc_cut       H.gtr.dp >-8.0 && H.gtr.dp <8.0
h_mom_high_cut      H.gtr.dp>8.0
h_mom_low_cut       H.gtr.dp<-8.0
p_mom_acc_cut       P.gtr.dp > -10 && P.gtr.dp < 22

detector_cut        h_mom_acc_cut && p_mom_acc_cut && pselect_e_cut # Bill's log 4482768

W_cut               abs(P.kin.primary.W - 1.230) < 0.05 # +- 5 MeV universal for all ndelta

#Q2_cut_vcs2_a        abs(P.kin.primary.Q2 - 0.05 ) < 0.01 # same for *d settings
Q2_cut_vcs2_c        abs(P.kin.primary.Q2 - 0.25 ) < 0.01 # same for *a settings

th_pq_cut_vcs2_1c    abs(H.kin.secondary.thx_cm * 180/3.141952 - 10) < 5
th_pq_cut_vcs2_2c    abs(H.kin.secondary.thx_cm * 180/3.141592 - 10) < 5
th_pq_cut_vcs2_3c    abs(H.kin.secondary.thx_cm * 180/3.141592 - 30) < 5
th_pq_cut_vcs2_4c    abs(H.kin.secondary.thx_cm * 180/3.141592 - 30) < 5
th_pq_cut_vcs2_5c    abs(H.kin.secondary.thx_cm * 180/3.141592 - 50) < 5
th_pq_cut_vcs2_6c    abs(H.kin.secondary.thx_cm * 180/3.141592 - 50) < 5
th_pq_cut_vcs2_7c    abs(H.kin.secondary.thx_cm * 180/3.141592 - 65) < 5

vcs2_cut_vcs2_1c     W_cut && Q2_cut_vcs2_c && th_pq_cut_vcs2_1c
vcs2_cut_vcs2_2c     W_cut && Q2_cut_vcs2_c && th_pq_cut_vcs2_2c
vcs2_cut_vcs2_3c     W_cut && Q2_cut_vcs2_c && th_pq_cut_vcs2_3c
vcs2_cut_vcs2_4c     W_cut && Q2_cut_vcs2_c && th_pq_cut_vcs2_4c
vcs2_cut_vcs2_5c     W_cut && Q2_cut_vcs2_c && th_pq_cut_vcs2_5c
vcs2_cut_vcs2_6c     W_cut && Q2_cut_vcs2_c && th_pq_cut_vcs2_6c
vcs2_cut_vcs2_7c     W_cut && Q2_cut_vcs2_c && th_pq_cut_vcs2_7c

ana_vcs2_1c          vcs2_cut_vcs2_1c && detector_cut
ana_vcs2_2c          vcs2_cut_vcs2_2c && detector_cut
ana_vcs2_3c          vcs2_cut_vcs2_3c && detector_cut
